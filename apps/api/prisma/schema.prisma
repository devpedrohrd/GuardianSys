generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  INVESTIGATOR
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  ACTIVE // Ativo
  PAST_DUE // Inadimplente
  CANCELED // Cancelado
}

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(255)
  slug               String   @unique @db.VarChar(100)
  customDomain       String?  @unique @map("custom_domain") @db.VarChar(255)
  logoUrl            String?  @map("logo_url") @db.VarChar(500)
  faviconUrl         String?  @map("favicon_url") @db.VarChar(500)
  primaryColor       String?  @map("primary_color") @db.VarChar(7)
  secondaryColor     String?  @map("secondary_color") @db.VarChar(7)
  displayName        String?  @map("display_name") @db.VarChar(255)
  document           String?  @db.VarChar(20)
  email              String?  @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  address            String?  @db.VarChar(500)

  plan               Plan?    @default(BASIC)
  subscriptionStatus SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users              User[]
  @@map("tenants")
  @@index([id])
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String?  @map("tenant_id") @db.Uuid
  name              String   @db.VarChar(255)
  email             String   @db.VarChar(255)
  password          String   @map("password_hash") @db.VarChar(255)
  role              Role     @default(INVESTIGATOR)
  canManageProducts Boolean  @default(false) @map("can_manage_products")
  canCreateCharges  Boolean  @default(true) @map("can_create_charges")
  canExportData     Boolean  @default(false) @map("can_export_data")
  canReopenCases    Boolean  @default(false) @map("can_reopen_cases")
  canViewOthers     Boolean  @default(false) @map("can_view_others")
  canEditOthers     Boolean  @default(false) @map("can_edit_others")
  
  createdById       String?  @map("created_by_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy         User?              @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers      User[]             @relation("UserCreatedBy")

  @@index([tenantId,id])
  @@index([email])
  @@map("users")
}